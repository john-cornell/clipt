<UserControl x:Class="Clipt.Views.FileDropTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Clipt.Converters"
             xmlns:help="clr-namespace:Clipt.Help">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8"
                    Visibility="{Binding HasFiles, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding FileCount, StringFormat='Files: {0}'}"
                       Foreground="{DynamicResource AccentLightBrush}" FontSize="11"
                       FontWeight="SemiBold"
                       ToolTip="{x:Static help:HelpContent.CfHdropTooltip}" />
        </StackPanel>

        <!-- No files -->
        <TextBlock Grid.Row="1" Text="No file drop data on clipboard"
                   Foreground="{DynamicResource ForegroundDimBrush}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontSize="14"
                   Visibility="{Binding HasFiles, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />

        <!-- File list -->
        <DataGrid Grid.Row="1" ItemsSource="{Binding Files}"
                  Visibility="{Binding HasFiles, Converter={StaticResource BoolToVis}}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="200" />
                <DataGridTextColumn Header="Full Path" Binding="{Binding FullPath}" Width="*" />
                <DataGridTextColumn Header="Size" Binding="{Binding SizeFormatted}" Width="100" />
                <DataGridTextColumn Header="Last Modified" Binding="{Binding LastModified, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" Width="160" />
                <DataGridTemplateColumn Header="" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Open"
                                    Command="{Binding DataContext.OpenInExplorerCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                    Padding="8,2" FontSize="11" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
