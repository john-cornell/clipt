<UserControl x:Class="Clipt.Views.FormatsTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:help="clr-namespace:Clipt.Help">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding TotalFormats, StringFormat='Total formats: {0}'}"
                   Foreground="{DynamicResource AccentLightBrush}"
                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8" />

        <DataGrid Grid.Row="1" ItemsSource="{Binding Formats}" CanUserSortColumns="True"
                  SelectedItem="{Binding SelectedFormatRow}">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                    <Setter Property="ToolTip" Value="{Binding ShortDescription}" />
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Width="120"
                                    Binding="{Binding IdDisplay}">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="ID"
                                   ToolTip="{x:Static help:HelpContent.FormatIdTooltip}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Format Name" Binding="{Binding Name}" Width="220" />
                <DataGridTextColumn Header="Size (bytes)" Binding="{Binding SizeBytes}" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                            <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Size" Binding="{Binding SizeFormatted}" Width="80" />
                <DataGridTextColumn Width="180"
                                    Binding="{Binding HandleHex}">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="HGLOBAL Handle"
                                   ToolTip="{x:Static help:HelpContent.HglobalTooltip}" />
                    </DataGridTextColumn.Header>
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
                            <Setter Property="FontSize" Value="11" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridCheckBoxColumn Width="70"
                                        Binding="{Binding IsStandard, Mode=OneWay}">
                    <DataGridCheckBoxColumn.Header>
                        <TextBlock Text="Standard"
                                   ToolTip="{x:Static help:HelpContent.StandardFormatTooltip}" />
                    </DataGridCheckBoxColumn.Header>
                </DataGridCheckBoxColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Format info panel -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="8,6" MinHeight="40" Margin="0,4,0,0">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SelectedFormatRow}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentLightBrush}"
                           Text="{Binding SelectedFormatRow.Name}" Margin="0,0,0,4" />
                <TextBlock Text="{Binding SelectedFormatDescription}"
                           TextWrapping="Wrap" FontSize="11.5"
                           Foreground="{DynamicResource ForegroundBrush}" />
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
