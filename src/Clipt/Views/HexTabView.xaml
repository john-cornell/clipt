<UserControl x:Class="Clipt.Views.HexTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             xmlns:converters="clr-namespace:Clipt.Converters"
             xmlns:help="clr-namespace:Clipt.Help">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolConverter x:Key="InverseBool" />
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <WrapPanel Grid.Row="0" Margin="0,0,0,8" VerticalAlignment="Center">
            <TextBlock Text="Format:" Foreground="{DynamicResource ForegroundDimBrush}"
                       FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"
                       ToolTip="{x:Static help:HelpContent.HexDumpTooltip}" />
            <ComboBox ItemsSource="{Binding AvailableFormats}"
                      SelectedItem="{Binding SelectedFormat}"
                      MinWidth="250">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" ToolTip="{Binding Description}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Text="Bytes/Row:" Foreground="{DynamicResource ForegroundDimBrush}"
                       FontSize="11" VerticalAlignment="Center" Margin="20,0,6,0"
                       ToolTip="{x:Static help:HelpContent.BytesPerRowTooltip}" />
            <ComboBox SelectedItem="{Binding BytesPerRow}" MinWidth="60">
                <sys:Int32>8</sys:Int32>
                <sys:Int32>16</sys:Int32>
                <sys:Int32>32</sys:Int32>
            </ComboBox>

            <TextBlock Text="{Binding TotalBytes, StringFormat='Total: {0} bytes'}"
                       Foreground="{DynamicResource ForegroundDimBrush}"
                       FontSize="11" VerticalAlignment="Center" Margin="20,0,0,0" />
        </WrapPanel>

        <!-- Format info -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="8,6" Margin="0,0,0,4">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SelectedFormat}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentLightBrush}"
                           Text="{Binding SelectedFormat.Name, StringFormat='About: {0}'}"
                           Margin="0,0,0,4" />
                <TextBlock Text="{Binding SelectedFormatDetailedDescription}"
                           TextWrapping="Wrap" FontSize="11.5"
                           Foreground="{DynamicResource ForegroundBrush}" />
            </DockPanel>
        </Border>

        <!-- Edit toolbar -->
        <DockPanel Grid.Row="2" Margin="0,0,0,4">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="Apply to Clipboard" Command="{Binding ApplyHexToClipboardCommand}"
                        Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"
                        Margin="0,0,6,0" Padding="10,4" FontSize="11" />
                <Button Command="{Binding ToggleEditingCommand}" Padding="10,4" FontSize="11">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Content" Value="Edit" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                    <Setter Property="Content" Value="Cancel" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
            <TextBlock Text="{Binding EditStatusMessage}"
                       Foreground="{DynamicResource AccentLightBrush}" FontSize="11"
                       VerticalAlignment="Center" />
        </DockPanel>

        <!-- Hex dump: offset | hex | ASCII -->
        <Border Grid.Row="3" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                Background="{DynamicResource SurfaceBrush}">
            <ScrollViewer x:Name="HexScrollViewer"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Offset column -->
                    <TextBlock x:Name="OffsetTextBlock"
                               Grid.Column="0"
                               Text="{Binding OffsetColumn}"
                               FontFamily="{DynamicResource MonoFont}" FontSize="12"
                               Foreground="{DynamicResource ForegroundDimBrush}"
                               Padding="8,4,8,4" />

                    <!-- Hex column -->
                    <TextBox x:Name="HexTextBox"
                             Grid.Column="1"
                             Text="{Binding HexColumn, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="{DynamicResource MonoFont}" FontSize="12"
                             Foreground="{DynamicResource ForegroundBrush}"
                             Background="Transparent"
                             BorderThickness="1,0,1,0"
                             BorderBrush="{DynamicResource BorderBrush}"
                             Padding="4"
                             IsReadOnly="{Binding IsEditing, Converter={StaticResource InverseBool}}"
                             TextWrapping="NoWrap"
                             AcceptsReturn="True"
                             HorizontalScrollBarVisibility="Disabled"
                             VerticalScrollBarVisibility="Disabled"
                             SelectionChanged="HexTextBox_SelectionChanged" />

                    <!-- ASCII column -->
                    <TextBox x:Name="AsciiTextBox"
                             Grid.Column="2"
                             Text="{Binding AsciiColumn, Mode=OneWay}"
                             FontFamily="{DynamicResource MonoFont}" FontSize="12"
                             Foreground="{DynamicResource ForegroundBrush}"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="4"
                             IsReadOnly="True"
                             TextWrapping="NoWrap"
                             AcceptsReturn="True"
                             HorizontalScrollBarVisibility="Disabled"
                             VerticalScrollBarVisibility="Disabled"
                             SelectionChanged="AsciiTextBox_SelectionChanged" />
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
