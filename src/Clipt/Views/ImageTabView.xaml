<UserControl x:Class="Clipt.Views.ImageTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Clipt.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Image info bar -->
        <WrapPanel Grid.Row="0" Margin="0,0,0,8"
                   Visibility="{Binding HasImage, Converter={StaticResource BoolToVis}}">
            <TextBlock Foreground="{DynamicResource AccentLightBrush}" FontSize="11"
                       FontWeight="SemiBold" Text="{Binding ImageSummary}" Margin="0,0,16,0" />
            <TextBlock Foreground="{DynamicResource ForegroundDimBrush}" FontSize="11"
                       Text="{Binding PixelFormat, StringFormat='Format: {0}'}" Margin="0,0,16,0" />
            <TextBlock Foreground="{DynamicResource ForegroundDimBrush}" FontSize="11"
                       Text="{Binding Stride, StringFormat='Stride: {0}'}" Margin="0,0,16,0" />
            <TextBlock Foreground="{DynamicResource ForegroundDimBrush}" FontSize="11"
                       Text="{Binding PaletteInfo}" />
        </WrapPanel>

        <!-- No image -->
        <TextBlock Grid.Row="1" Text="No image data on clipboard"
                   Foreground="{DynamicResource ForegroundDimBrush}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontSize="14"
                   Visibility="{Binding HasImage, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />

        <!-- Image preview -->
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding HasImage, Converter={StaticResource BoolToVis}}">
            <Border Background="#FF0A0A0A" Padding="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <Image Source="{Binding ImageSource}"
                       Stretch="None"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                       RenderOptions.EdgeMode="Aliased" />
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
