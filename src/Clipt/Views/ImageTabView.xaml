<UserControl x:Class="Clipt.Views.ImageTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Clipt.Converters"
             xmlns:help="clr-namespace:Clipt.Help">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Image info bar -->
        <WrapPanel Grid.Row="0" Margin="0,0,0,8"
                   Visibility="{Binding HasImage, Converter={StaticResource BoolToVis}}">
            <TextBlock Foreground="{DynamicResource AccentLightBrush}" FontSize="11"
                       FontWeight="SemiBold" Text="{Binding ImageSummary}" Margin="0,0,16,0"
                       ToolTip="{x:Static help:HelpContent.BppTooltip}" />
            <TextBlock Foreground="{DynamicResource ForegroundDimBrush}" FontSize="11"
                       Text="{Binding PixelFormat, StringFormat='Format: {0}'}" Margin="0,0,16,0"
                       ToolTip="{x:Static help:HelpContent.PixelFormatTooltip}" />
            <TextBlock Foreground="{DynamicResource ForegroundDimBrush}" FontSize="11"
                       Text="{Binding Stride, StringFormat='Stride: {0}'}" Margin="0,0,16,0"
                       ToolTip="{x:Static help:HelpContent.StrideTooltip}" />
            <TextBlock Foreground="{DynamicResource ForegroundDimBrush}" FontSize="11"
                       Text="{Binding PaletteInfo}"
                       ToolTip="{x:Static help:HelpContent.PaletteTooltip}" />
        </WrapPanel>

        <!-- No image (only when no error either) -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding HasImage}" Value="False" />
                                <Condition Binding="{Binding HasError}" Value="False" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible" />
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <TextBlock Text="No image data on clipboard"
                       Foreground="{DynamicResource ForegroundDimBrush}"
                       HorizontalAlignment="Center"
                       FontSize="14" />
        </StackPanel>

        <!-- Decode error -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Image decode failed"
                       Foreground="{DynamicResource ErrorBrush}"
                       HorizontalAlignment="Center"
                       FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource ForegroundDimBrush}"
                       HorizontalAlignment="Center"
                       FontSize="12" TextWrapping="Wrap" MaxWidth="500" />
        </StackPanel>

        <!-- Image preview -->
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding HasImage, Converter={StaticResource BoolToVis}}">
            <Border Background="{DynamicResource BackgroundBrush}" Padding="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <Image Source="{Binding ImageSource}"
                       Stretch="None"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                       RenderOptions.EdgeMode="Aliased" />
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
