<UserControl x:Class="Clipt.Views.NativeTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:help="clr-namespace:Clipt.Help">
    <UserControl.Resources>
        <Style x:Key="NativeLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundDimBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
        <Style x:Key="NativeValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
            <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,24,0" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Global info -->
        <WrapPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Style="{StaticResource NativeLabel}" Text="Clipboard Owner:"
                       ToolTip="{x:Static help:HelpContent.ClipboardOwnerTooltip}" />
            <TextBlock Style="{StaticResource NativeValue}" Text="{Binding ClipboardOwner}" />
            <TextBlock Style="{StaticResource NativeLabel}" Text="Sequence #:"
                       ToolTip="{x:Static help:HelpContent.SequenceNumberTooltip}" />
            <TextBlock Style="{StaticResource NativeValue}" Text="{Binding SequenceNumber}" />
        </WrapPanel>

        <!-- Format selector -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Style="{StaticResource NativeLabel}" Text="Inspect Format:" />
            <ComboBox ItemsSource="{Binding AvailableFormats}"
                      SelectedItem="{Binding SelectedFormat}"
                      MinWidth="300" />
        </StackPanel>

        <!-- Memory details -->
        <WrapPanel Grid.Row="2" Margin="0,0,0,4">
            <TextBlock Style="{StaticResource NativeLabel}" Text="HGLOBAL Handle:"
                       ToolTip="{x:Static help:HelpContent.HglobalTooltip}" />
            <TextBlock Style="{StaticResource NativeValue}" Text="{Binding HandleHex}" />
        </WrapPanel>

        <WrapPanel Grid.Row="3" Margin="0,0,0,4">
            <TextBlock Style="{StaticResource NativeLabel}" Text="GlobalLock Pointer:"
                       ToolTip="{x:Static help:HelpContent.GlobalLockTooltip}" />
            <TextBlock Style="{StaticResource NativeValue}" Text="{Binding LockPointerHex}" />
            <TextBlock Style="{StaticResource NativeLabel}" Text="GlobalSize:"
                       ToolTip="{x:Static help:HelpContent.GlobalSizeTooltip}" />
            <TextBlock Style="{StaticResource NativeValue}" Text="{Binding GlobalSizeDisplay}" />
        </WrapPanel>

        <!-- Raw memory caption + step controls -->
        <StackPanel Grid.Row="4" Margin="0,8,0,4">
            <TextBlock Text="{Binding RawMemoryCaption}"
                       Foreground="{DynamicResource ForegroundDimBrush}"
                       FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"
                       ToolTip="{x:Static help:HelpContent.RawMemoryTooltip}" />
            <TextBlock Text="RAW MEMORY — HEX"
                       Foreground="{DynamicResource AccentLightBrush}"
                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4" />
            <WrapPanel Orientation="Horizontal">
                <Button Content="256" Margin="0,0,4,4" Padding="8,2" FontSize="10"
                        Command="{Binding SetRawMemoryByteStepCommand}" CommandParameter="0" />
                <Button Content="1K" Margin="0,0,4,4" Padding="8,2" FontSize="10"
                        Command="{Binding SetRawMemoryByteStepCommand}" CommandParameter="1" />
                <Button Content="4K" Margin="0,0,4,4" Padding="8,2" FontSize="10"
                        Command="{Binding SetRawMemoryByteStepCommand}" CommandParameter="2" />
                <Button Content="16K" Margin="0,0,4,4" Padding="8,2" FontSize="10"
                        Command="{Binding SetRawMemoryByteStepCommand}" CommandParameter="3" />
                <Button Content="Full" Margin="0,0,4,4" Padding="8,2" FontSize="10"
                        Command="{Binding SetRawMemoryByteStepCommand}" CommandParameter="4" />
                <Button Content="◀" Margin="8,0,4,4" Padding="8,2" FontSize="10"
                        ToolTip="Smaller preview"
                        Command="{Binding RetreatRawMemoryByteStepCommand}" />
                <Button Content="▶" Margin="0,0,0,4" Padding="8,2" FontSize="10"
                        ToolTip="Larger preview"
                        Command="{Binding AdvanceRawMemoryByteStepCommand}" />
            </WrapPanel>
        </StackPanel>

        <!-- Hex dump -->
        <TextBox Grid.Row="5"
                 Text="{Binding MemoryHexDump, Mode=OneWay}"
                 Style="{DynamicResource MonoText}"
                 AcceptsReturn="True" />
    </Grid>
</UserControl>
