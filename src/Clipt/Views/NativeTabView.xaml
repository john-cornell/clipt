<UserControl x:Class="Clipt.Views.NativeTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="NativeLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundDimBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
        <Style x:Key="NativeValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
            <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,24,0" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Global info -->
        <WrapPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Style="{StaticResource NativeLabel}" Text="Clipboard Owner:" />
            <TextBlock Style="{StaticResource NativeValue}" Text="{Binding ClipboardOwner}" />
            <TextBlock Style="{StaticResource NativeLabel}" Text="Sequence #:" />
            <TextBlock Style="{StaticResource NativeValue}" Text="{Binding SequenceNumber}" />
        </WrapPanel>

        <!-- Format selector -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Style="{StaticResource NativeLabel}" Text="Inspect Format:" />
            <ComboBox ItemsSource="{Binding AvailableFormats}"
                      SelectedItem="{Binding SelectedFormat}"
                      MinWidth="300" />
        </StackPanel>

        <!-- Memory details -->
        <WrapPanel Grid.Row="2" Margin="0,0,0,4">
            <TextBlock Style="{StaticResource NativeLabel}" Text="HGLOBAL Handle:" />
            <TextBlock Style="{StaticResource NativeValue}" Text="{Binding HandleHex}" />
        </WrapPanel>

        <WrapPanel Grid.Row="3" Margin="0,0,0,4">
            <TextBlock Style="{StaticResource NativeLabel}" Text="GlobalLock Pointer:" />
            <TextBlock Style="{StaticResource NativeValue}" Text="{Binding LockPointerHex}" />
            <TextBlock Style="{StaticResource NativeLabel}" Text="GlobalSize:" />
            <TextBlock Style="{StaticResource NativeValue}" Text="{Binding GlobalSizeDisplay}" />
        </WrapPanel>

        <!-- Hex dump header -->
        <TextBlock Grid.Row="4" Text="FIRST 256 BYTES — RAW MEMORY"
                   Foreground="{DynamicResource AccentLightBrush}"
                   FontSize="11" FontWeight="SemiBold" Margin="0,8,0,4" />

        <!-- Hex dump -->
        <TextBox Grid.Row="5"
                 Text="{Binding MemoryHexDump, Mode=OneWay}"
                 Style="{DynamicResource MonoText}"
                 AcceptsReturn="True" />
    </Grid>
</UserControl>
