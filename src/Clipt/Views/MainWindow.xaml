<Window x:Class="Clipt.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Clipt.Views"
        xmlns:converters="clr-namespace:Clipt.Converters"
        xmlns:help="clr-namespace:Clipt.Help"
        Title="Clipt — Clipboard Inspector"
        Icon="pack://application:,,,/Icons/icon.ico"
        Width="1100" Height="750"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="12,6">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <ToggleButton Content="?" IsChecked="{Binding IsHelpVisible}"
                                  ToolTip="Toggle detailed help panel for the current tab"
                                  Width="28" Height="28" Padding="0"
                                  FontWeight="Bold" FontSize="14"
                                  VerticalAlignment="Center" Margin="0,0,12,0" />
                    <CheckBox Content="Dark Mode" IsChecked="{Binding IsDarkMode}"
                              Foreground="{DynamicResource ForegroundBrush}"
                              VerticalAlignment="Center" Margin="0,0,12,0" />
                    <CheckBox Content="Auto-refresh" IsChecked="{Binding AutoRefresh}"
                              ToolTip="{x:Static help:HelpContent.AutoRefreshTooltip}"
                              Foreground="{DynamicResource ForegroundBrush}"
                              VerticalAlignment="Center" Margin="0,0,12,0" />
                    <Button Content="Refresh Now" Command="{Binding RefreshCommand}" />
                </StackPanel>

                <TextBlock Text="Clipt" FontSize="16" FontWeight="Bold"
                           Foreground="{DynamicResource AccentBrush}"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <!-- Help panel -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                MaxHeight="200"
                Visibility="{Binding IsHelpVisible, Converter={StaticResource BoolToVis}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,8">
                <ItemsControl ItemsSource="{Binding CurrentHelpEntries}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="12,4,12,4">
                                <TextBlock Text="{Binding Term}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentBrush}" FontSize="12" />
                                <TextBlock Text="{Binding Description}" TextWrapping="Wrap"
                                           Foreground="{DynamicResource ForegroundBrush}" FontSize="11.5"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Tab area -->
        <TabControl Grid.Row="2" SelectedIndex="{Binding SelectedTabIndex}">
            <TabItem Header="Text">
                <views:TextTabView DataContext="{Binding TextTab}" />
            </TabItem>
            <TabItem Header="Hex">
                <views:HexTabView DataContext="{Binding HexTab}" />
            </TabItem>
            <TabItem Header="Image">
                <views:ImageTabView DataContext="{Binding ImageTab}" />
            </TabItem>
            <TabItem Header="Rich Content">
                <views:RichContentTabView DataContext="{Binding RichContentTab}" />
            </TabItem>
            <TabItem Header="File Drop">
                <views:FileDropTabView DataContext="{Binding FileDropTab}" />
            </TabItem>
            <TabItem Header="All Formats">
                <views:FormatsTabView DataContext="{Binding FormatsTab}" />
            </TabItem>
            <TabItem Header="Native / Memory">
                <views:NativeTabView DataContext="{Binding NativeTab}" />
            </TabItem>
        </TabControl>

        <!-- Status bar -->
        <StatusBar Grid.Row="3">
            <StatusBarItem Content="{Binding StatusTimestamp}" />
            <Separator Background="#40FFFFFF" />
            <StatusBarItem Content="{Binding StatusSequence}"
                           ToolTip="{x:Static help:HelpContent.SeqStatusTooltip}" />
            <Separator Background="#40FFFFFF" />
            <StatusBarItem Content="{Binding StatusFormats}"
                           ToolTip="{x:Static help:HelpContent.FormatsCountTooltip}" />
            <Separator Background="#40FFFFFF" />
            <StatusBarItem Content="{Binding StatusOwner}"
                           ToolTip="{x:Static help:HelpContent.OwnerStatusTooltip}" />
        </StatusBar>
    </Grid>
</Window>
