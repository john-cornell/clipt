<Window x:Class="Clipt.Views.TrayPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Clipt.Converters"
        xmlns:models="clr-namespace:Clipt.Models"
        Title="Clipt"
        Width="360" Height="420"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Border Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                    Padding="10,6" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="&#x2197;"
                            ToolTip="Expand to full window"
                            Command="{Binding ExpandToFullCommand}"
                            Width="28" Height="28" Padding="0"
                            FontSize="16" />
                    <ToggleButton DockPanel.Dock="Right"
                                  IsChecked="{Binding IsPinned}"
                                  Width="28" Height="28" Padding="0"
                                  FontSize="14" Margin="0,0,4,0">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Content" Value="&#x25CB;" />
                                <Setter Property="ToolTip" Value="Pin window" />
                                <Style.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter Property="Content" Value="&#x25C9;" />
                                        <Setter Property="ToolTip" Value="Unpin window" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>
                    <TextBlock x:Name="TitleText" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center" />
                </DockPanel>
            </Border>

            <!-- Tabs -->
            <TabControl Grid.Row="1" Margin="0">
                <TabItem Header="Clipboard">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10,8">
                        <StackPanel>
                            <!-- Summary -->
                            <TextBlock Text="{Binding ClipboardSummary}"
                                       Foreground="{DynamicResource ForegroundDimBrush}"
                                       FontSize="12" Margin="0,0,0,8" />

                            <!-- Empty state -->
                            <TextBlock Text="Nothing on the clipboard."
                                       Foreground="{DynamicResource ForegroundDimBrush}"
                                       FontSize="12" FontStyle="Italic"
                                       Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"
                                       Margin="0,16,0,0"
                                       HorizontalAlignment="Center" />

                            <!-- Text preview -->
                            <StackPanel Visibility="{Binding HasText, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Text" FontWeight="SemiBold" FontSize="11"
                                           Foreground="{DynamicResource AccentLightBrush}"
                                           Margin="0,0,0,4" />
                                <TextBox Text="{Binding PreviewText, Mode=OneWay}"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         MaxHeight="140"
                                         VerticalScrollBarVisibility="Auto"
                                         FontSize="12"
                                         Margin="0,0,0,8" />
                            </StackPanel>

                            <!-- Image preview -->
                            <StackPanel Visibility="{Binding HasImage, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Image" FontWeight="SemiBold" FontSize="11"
                                           Foreground="{DynamicResource AccentLightBrush}"
                                           Margin="0,0,0,4" />
                                <Border BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1" MaxHeight="160"
                                        Margin="0,0,0,8">
                                    <Image Source="{Binding PreviewImage}"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                </Border>
                            </StackPanel>

                            <!-- File preview -->
                            <StackPanel Visibility="{Binding HasFiles, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Files" FontWeight="SemiBold" FontSize="11"
                                           Foreground="{DynamicResource AccentLightBrush}"
                                           Margin="0,0,0,4" />
                                <ItemsControl ItemsSource="{Binding PreviewFiles}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       Foreground="{DynamicResource ForegroundBrush}"
                                                       FontSize="11"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,1" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="History" DataContext="{Binding HistoryTab}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="10,6,10,4">
                            <Button DockPanel.Dock="Right" Content="Clear history"
                                    Command="{Binding ClearAllCommand}"
                                    FontSize="11" Padding="8,2" Margin="8,0,0,0" />
                            <CheckBox DockPanel.Dock="Right"
                                      Content="Clear clipboard too"
                                      IsChecked="{Binding AlsoClearClipboardOnClearHistory}"
                                      FontSize="11"
                                      VerticalAlignment="Center"
                                      ToolTip="Also clear the system clipboard when clearing history" />
                            <TextBlock Text="{Binding StatusText}"
                                       Foreground="{DynamicResource ForegroundDimBrush}"
                                       FontSize="11" VerticalAlignment="Center" />
                        </DockPanel>

                        <TextBlock Grid.Row="1" Text="No clipboard history yet."
                                   Foreground="{DynamicResource ForegroundDimBrush}"
                                   FontSize="12" FontStyle="Italic"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}" />

                        <ItemsControl Grid.Row="1" ItemsSource="{Binding DisplayEntries}"
                                      Margin="0,2,0,0">
                            <ItemsControl.Template>
                                <ControlTemplate TargetType="ItemsControl">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </ControlTemplate>
                            </ItemsControl.Template>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="0,0,0,1" Padding="10,6"
                                            ToolTipService.InitialShowDelay="400"
                                            ToolTipService.ShowDuration="30000"
                                            ToolTipOpening="HistoryEntry_ToolTipOpening"
                                            ToolTip="{Binding PreviewThumbnail}">
                                        <Border.Resources>
                                            <Style TargetType="ToolTip">
                                                <Setter Property="MaxWidth" Value="220" />
                                                <Setter Property="MaxHeight" Value="220" />
                                                <Setter Property="Padding" Value="4" />
                                                <Setter Property="ContentTemplate">
                                                    <Setter.Value>
                                                        <DataTemplate>
                                                            <Image Source="{Binding}"
                                                                   Stretch="Uniform"
                                                                   RenderOptions.BitmapScalingMode="HighQuality" />
                                                        </DataTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Border.Resources>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Editable name row -->
                                            <TextBlock Grid.Column="0" Grid.ColumnSpan="4" Grid.Row="0"
                                                       Text="{Binding Name}"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource ForegroundBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,0,0,2" Cursor="Hand"
                                                       MouseLeftButtonDown="HistoryEntryName_MouseLeftButtonDown"
                                                       Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                                                <TextBlock.ToolTip>
                                                    <ToolTip Content="Click to edit">
                                                        <ToolTip.ContentTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding}" />
                                                            </DataTemplate>
                                                        </ToolTip.ContentTemplate>
                                                    </ToolTip>
                                                </TextBlock.ToolTip>
                                            </TextBlock>
                                            <TextBox Grid.Column="0" Grid.ColumnSpan="4" Grid.Row="0"
                                                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                     FontSize="11" FontWeight="SemiBold"
                                                     Margin="0,0,0,2" Padding="0"
                                                     IsVisibleChanged="HistoryEntryNameEdit_IsVisibleChanged"
                                                     LostFocus="HistoryEntryNameEdit_LostFocus"
                                                     KeyDown="HistoryEntryNameEdit_KeyDown"
                                                     Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}" />

                                            <Button Grid.Column="0" Grid.Row="1"
                                                    Command="{Binding PreviewCommand}"
                                                    Margin="0,0,6,0"
                                                    VerticalAlignment="Center"
                                                    Cursor="Hand"
                                                    ToolTip="Click to preview full size">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <ContentPresenter />
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding PreviewCommand}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding InlineThumbnail}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <Image Source="{Binding InlineThumbnail}"
                                                       Width="28" Height="28"
                                                       Stretch="Uniform"
                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                            </Button>

                                            <TextBlock Grid.Column="1" Grid.Row="1"
                                                       Text="{Binding ContentTypeLabel}"
                                                       FontWeight="SemiBold" FontSize="11"
                                                       Foreground="{DynamicResource AccentLightBrush}"
                                                       Margin="0,0,6,0" VerticalAlignment="Center" />

                                            <TextBlock Grid.Column="2" Grid.Row="1"
                                                       Text="{Binding Summary}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource ForegroundBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" />

                                            <TextBlock Grid.Column="3" Grid.Row="1"
                                                       Text="{Binding RelativeTime}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource ForegroundDimBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="6,0,0,0" />

                                            <StackPanel Grid.Column="2" Grid.ColumnSpan="2"
                                                        Grid.Row="2" Orientation="Horizontal"
                                                        HorizontalAlignment="Right" Margin="0,3,0,0">
                                                <Button Content="Restore" FontSize="10"
                                                        Padding="8,1"
                                                        Command="{Binding RestoreCommand}" Margin="0,0,4,0"
                                                        Visibility="{Binding IsCurrent, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
                                                <Button Content="X" FontSize="10"
                                                        Padding="6,1" ToolTip="Delete"
                                                        Command="{Binding DeleteCommand}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</Window>
