<Window x:Class="Clipt.Views.TrayPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Clipt.Converters"
        xmlns:models="clr-namespace:Clipt.Models"
        Title="Clipt"
        Width="360" Height="420"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:AllTrueToVisibilityConverter x:Key="AllTrueToVis" />
        <Style x:Key="TrayLinkButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource AccentLightBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                    Padding="10,6,0,6" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <DockPanel>
                    <!-- Pin button: far right, close-button style -->
                    <ToggleButton DockPanel.Dock="Right"
                                  IsChecked="{Binding IsPinned}"
                                  Width="36" Height="30" Padding="0"
                                  FontSize="16" Margin="0"
                                  VerticalAlignment="Stretch">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Content" Value="&#x25CB;" />
                                <Setter Property="ToolTip" Value="Pin window" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="Bd"
                                                    Background="Transparent"
                                                    CornerRadius="0,4,0,0">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background"
                                                            Value="{DynamicResource AccentBrush}" />
                                                    <Setter Property="Foreground" Value="White" />
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="Bd" Property="Background"
                                                            Value="{DynamicResource AccentLightBrush}" />
                                                    <Setter Property="Foreground" Value="White" />
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter Property="Content" Value="&#x25C9;" />
                                                    <Setter Property="ToolTip" Value="Unpin window" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>

                    <!-- Title + expand button together on the left -->
                    <TextBlock x:Name="TitleText" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center" />
                    <Button Content="&#x2197;"
                            ToolTip="Expand to full window"
                            Command="{Binding ExpandToFullCommand}"
                            Width="26" Height="26" Padding="0"
                            FontSize="14" Margin="6,0,0,0"
                            VerticalAlignment="Center" HorizontalAlignment="Left">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="3"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background"
                                                            Value="{DynamicResource AccentBrush}" />
                                                    <Setter Property="Foreground" Value="White" />
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="Bd" Property="Background"
                                                            Value="{DynamicResource AccentLightBrush}" />
                                                    <Setter Property="Foreground" Value="White" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </DockPanel>
            </Border>

            <!-- Tabs -->
            <TabControl Grid.Row="1" Margin="0">
                <TabItem Header="Clipboard">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10,8">
                        <StackPanel>
                            <!-- Summary -->
                            <TextBlock Text="{Binding ClipboardSummary}"
                                       Foreground="{DynamicResource ForegroundDimBrush}"
                                       FontSize="12" Margin="0,0,0,8" />

                            <!-- Empty state -->
                            <TextBlock Text="Nothing on the clipboard."
                                       Foreground="{DynamicResource ForegroundDimBrush}"
                                       FontSize="12" FontStyle="Italic"
                                       Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"
                                       Margin="0,16,0,0"
                                       HorizontalAlignment="Center" />

                            <!-- Text preview -->
                            <StackPanel Visibility="{Binding HasText, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Text" FontWeight="SemiBold" FontSize="11"
                                           Foreground="{DynamicResource AccentLightBrush}"
                                           Margin="0,0,0,4" />
                                <StackPanel Visibility="{Binding TextPreviewStepControlsVisible, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{Binding TextPreviewCaption}"
                                               Foreground="{DynamicResource ForegroundDimBrush}"
                                               FontSize="10" TextWrapping="Wrap" Margin="0,0,0,4" />
                                    <WrapPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Button Content="500" Margin="0,0,4,0" Padding="6,2" FontSize="10"
                                                Command="{Binding SetTrayTextPreviewStepCommand}" CommandParameter="0" />
                                        <Button Content="2K" Margin="0,0,4,0" Padding="6,2" FontSize="10"
                                                Command="{Binding SetTrayTextPreviewStepCommand}" CommandParameter="1" />
                                        <Button Content="8K" Margin="0,0,4,0" Padding="6,2" FontSize="10"
                                                Command="{Binding SetTrayTextPreviewStepCommand}" CommandParameter="2" />
                                        <Button Content="Full" Margin="0,0,4,0" Padding="6,2" FontSize="10"
                                                Command="{Binding SetTrayTextPreviewStepCommand}" CommandParameter="3" />
                                        <Button Content="◀" Margin="6,0,4,0" Padding="6,2" FontSize="10"
                                                ToolTip="Less text"
                                                Command="{Binding RetreatTrayTextPreviewStepCommand}" />
                                        <Button Content="▶" Margin="0,0,0,0" Padding="6,2" FontSize="10"
                                                ToolTip="More text"
                                                Command="{Binding AdvanceTrayTextPreviewStepCommand}" />
                                    </WrapPanel>
                                </StackPanel>
                                <TextBox Text="{Binding PreviewText, Mode=OneWay}"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         MaxHeight="140"
                                         VerticalScrollBarVisibility="Auto"
                                         FontSize="12"
                                         Margin="0,0,0,8" />
                            </StackPanel>

                            <!-- Image preview -->
                            <StackPanel Visibility="{Binding HasImage, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Image" FontWeight="SemiBold" FontSize="11"
                                           Foreground="{DynamicResource AccentLightBrush}"
                                           Margin="0,0,0,4" />
                                <Border BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1" MaxHeight="160"
                                        Margin="0,0,0,8">
                                    <Image Source="{Binding PreviewImage}"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                </Border>
                            </StackPanel>

                            <!-- File preview -->
                            <StackPanel Visibility="{Binding HasFiles, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Files" FontWeight="SemiBold" FontSize="11"
                                           Foreground="{DynamicResource AccentLightBrush}"
                                           Margin="0,0,0,4" />
                                <ItemsControl ItemsSource="{Binding PreviewFiles}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       Foreground="{DynamicResource ForegroundBrush}"
                                                       FontSize="11"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,1" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="History" DataContext="{Binding HistoryTab}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="10,6,10,4">
                            <DockPanel
                                Visibility="{Binding ShowNormalHistoryChrome, Converter={StaticResource BoolToVis}}">
                                <Menu DockPanel.Dock="Right"
                                      Background="Transparent"
                                      VerticalAlignment="Center"
                                      Margin="8,0,0,0">
                                    <Menu.Resources>
                                        <Style TargetType="MenuItem">
                                            <Setter Property="Foreground"
                                                    Value="{DynamicResource ForegroundBrush}" />
                                        </Style>
                                    </Menu.Resources>
                                    <MenuItem Header="&#x2261;"
                                              FontSize="16"
                                              Padding="6,2"
                                              ToolTip="History actions">
                                        <MenuItem Header="Save group…"
                                                  Command="{Binding EnterSelectionModeCommand}"
                                                  ToolTip="Select entries to save as a named group" />
                                        <MenuItem Header="Reorder items"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding ShowMoveControls, Mode=TwoWay}"
                                                  ToolTip="Show up/down controls to reorder history" />
                                        <MenuItem Header="Long text (More/Less)"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding ShowTextExpandControls, Mode=TwoWay}"
                                                  ToolTip="Show More and Less under text entries when the summary may be long" />
                                        <Separator />
                                        <MenuItem Header="Clear">
                                            <MenuItem Header="Clear all"
                                                      Command="{Binding ClearAllIncludingClipboardCommand}"
                                                      ToolTip="Remove all history and clear the system clipboard" />
                                            <MenuItem Header="Clear history only"
                                                      Command="{Binding ClearHistoryOnlyCommand}"
                                                      ToolTip="Remove history; keep current clipboard content" />
                                        </MenuItem>
                                    </MenuItem>
                                </Menu>
                                <TextBlock Text="{Binding StatusText}"
                                           Foreground="{DynamicResource ForegroundDimBrush}"
                                           FontSize="11" VerticalAlignment="Center" />
                            </DockPanel>
                            <DockPanel
                                Visibility="{Binding ShowSelectionHistoryChrome, Converter={StaticResource BoolToVis}}">
                                <Button DockPanel.Dock="Right" Content="Save selected"
                                        Command="{Binding BeginSaveSelectedCommand}"
                                        FontSize="11" Padding="8,2" Margin="8,0,0,0" />
                                <Button DockPanel.Dock="Right" Content="Cancel"
                                        Command="{Binding CancelSelectionModeCommand}"
                                        Style="{StaticResource TrayLinkButton}"
                                        Margin="8,0,0,0" />
                                <TextBlock Text="{Binding StatusText}"
                                           Foreground="{DynamicResource ForegroundDimBrush}"
                                           FontSize="11" VerticalAlignment="Center" />
                            </DockPanel>
                            <DockPanel
                                Visibility="{Binding ShowNamingHistoryChrome, Converter={StaticResource BoolToVis}}">
                                <Button DockPanel.Dock="Right" Content="OK"
                                        Command="{Binding ConfirmSaveGroupCommand}"
                                        FontSize="11" Padding="10,2" Margin="8,0,0,0" />
                                <Button DockPanel.Dock="Right" Content="Cancel"
                                        Command="{Binding CancelNamingCommand}"
                                        Style="{StaticResource TrayLinkButton}"
                                        Margin="8,0,0,0" />
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding StatusText}"
                                               Foreground="{DynamicResource ForegroundDimBrush}"
                                               FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="Name:"
                                               Foreground="{DynamicResource ForegroundDimBrush}"
                                               FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0" />
                                    <TextBox MinWidth="120" MaxWidth="180" FontSize="11"
                                             VerticalAlignment="Center"
                                             Text="{Binding NewGroupName, UpdateSourceTrigger=PropertyChanged}"
                                             IsVisibleChanged="GroupNameEdit_IsVisibleChanged"
                                             KeyDown="GroupNameEdit_KeyDown" />
                                </StackPanel>
                            </DockPanel>
                        </Grid>

                        <TextBlock Grid.Row="1" Text="No clipboard history yet."
                                   Foreground="{DynamicResource ForegroundDimBrush}"
                                   FontSize="12" FontStyle="Italic"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}" />

                        <ItemsControl Grid.Row="1" ItemsSource="{Binding DisplayEntries}"
                                      Margin="0,2,0,0">
                            <ItemsControl.Template>
                                <ControlTemplate TargetType="ItemsControl">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </ControlTemplate>
                            </ItemsControl.Template>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="0,0,0,1" Padding="10,6"
                                            ToolTipService.InitialShowDelay="400"
                                            ToolTipService.ShowDuration="30000"
                                            ToolTipOpening="HistoryEntry_ToolTipOpening"
                                            ToolTip="{Binding PreviewThumbnail}">
                                        <Border.Resources>
                                            <Style TargetType="ToolTip">
                                                <Setter Property="MaxWidth" Value="220" />
                                                <Setter Property="MaxHeight" Value="220" />
                                                <Setter Property="Padding" Value="4" />
                                                <Setter Property="ContentTemplate">
                                                    <Setter.Value>
                                                        <DataTemplate>
                                                            <Image Source="{Binding}"
                                                                   Stretch="Uniform"
                                                                   RenderOptions.BitmapScalingMode="HighQuality" />
                                                        </DataTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Border.Resources>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <CheckBox Grid.Column="0" Grid.Row="0" Grid.RowSpan="3"
                                                      VerticalAlignment="Center" Margin="0,0,6,0"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      Visibility="{Binding DataContext.IsSelectionMode, RelativeSource={RelativeSource AncestorType=ItemsControl}, Converter={StaticResource BoolToVis}}" />

                                            <StackPanel Grid.Column="1" Grid.Row="0" Grid.RowSpan="3"
                                                        VerticalAlignment="Center" Margin="0,0,6,0"
                                                        Visibility="{Binding DataContext.ShowMoveControls, RelativeSource={RelativeSource AncestorType=ItemsControl}, Converter={StaticResource BoolToVis}}">
                                                <Button Content="&#x25B2;" FontSize="9" Padding="2,0"
                                                        Command="{Binding MoveUpCommand}"
                                                        ToolTip="Move up in history">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding MoveUpCommand}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Hidden" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                                <Button Content="&#x25BC;" FontSize="9" Padding="2,0"
                                                        Command="{Binding MoveDownCommand}"
                                                        ToolTip="Move down in history">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding MoveDownCommand}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Hidden" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>

                                            <!-- Editable name row -->
                                            <TextBlock Grid.Column="2" Grid.ColumnSpan="4" Grid.Row="0"
                                                       Text="{Binding Name}"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource ForegroundBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,0,0,2" Cursor="Hand"
                                                       MouseLeftButtonDown="HistoryEntryName_MouseLeftButtonDown"
                                                       Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                                                <TextBlock.ToolTip>
                                                    <ToolTip Content="Click to edit">
                                                        <ToolTip.ContentTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding}" />
                                                            </DataTemplate>
                                                        </ToolTip.ContentTemplate>
                                                    </ToolTip>
                                                </TextBlock.ToolTip>
                                            </TextBlock>
                                            <TextBox Grid.Column="2" Grid.ColumnSpan="4" Grid.Row="0"
                                                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                     FontSize="11" FontWeight="SemiBold"
                                                     Margin="0,0,0,2" Padding="0"
                                                     IsVisibleChanged="HistoryEntryNameEdit_IsVisibleChanged"
                                                     LostFocus="HistoryEntryNameEdit_LostFocus"
                                                     KeyDown="HistoryEntryNameEdit_KeyDown"
                                                     Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}" />

                                            <Button Grid.Column="2" Grid.Row="1"
                                                    Command="{Binding PreviewCommand}"
                                                    Margin="0,0,6,0"
                                                    VerticalAlignment="Center"
                                                    Cursor="Hand"
                                                    ToolTip="Click to preview full size">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <ContentPresenter />
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding PreviewCommand}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding InlineThumbnail}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <Image Source="{Binding InlineThumbnail}"
                                                       Width="28" Height="28"
                                                       Stretch="Uniform"
                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                            </Button>

                                            <TextBlock Grid.Column="3" Grid.Row="1"
                                                       Text="{Binding ContentTypeLabel}"
                                                       FontWeight="SemiBold" FontSize="11"
                                                       Foreground="{DynamicResource AccentLightBrush}"
                                                       Margin="0,0,6,0" VerticalAlignment="Center" />

                                            <StackPanel Grid.Column="4" Grid.Row="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding SummaryDisplay}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource ForegroundBrush}"
                                                           TextWrapping="Wrap"
                                                           MaxHeight="160" />
                                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                    <StackPanel.Visibility>
                                                        <MultiBinding Converter="{StaticResource AllTrueToVis}">
                                                            <Binding Path="SummaryExpandChromeVisible" />
                                                            <Binding Path="DataContext.ShowTextExpandControls"
                                                                     RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                        </MultiBinding>
                                                    </StackPanel.Visibility>
                                                    <Button Content="More" FontSize="10" Padding="8,1" Margin="0,0,4,0"
                                                            Command="{Binding ExpandHistorySummaryCommand}" />
                                                    <Button Content="Less" FontSize="10" Padding="8,1"
                                                            Command="{Binding RetreatHistorySummaryCommand}" />
                                                </StackPanel>
                                            </StackPanel>

                                            <TextBlock Grid.Column="5" Grid.Row="1"
                                                       Text="{Binding RelativeTime}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource ForegroundDimBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="6,0,0,0" />

                                            <StackPanel Grid.Column="4" Grid.ColumnSpan="2"
                                                        Grid.Row="2" Orientation="Horizontal"
                                                        HorizontalAlignment="Right" Margin="0,3,0,0">
                                                <Button Content="Restore" FontSize="10"
                                                        Padding="8,1"
                                                        Command="{Binding RestoreCommand}" Margin="0,0,4,0"
                                                        Visibility="{Binding IsCurrent, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
                                                <Button Content="X" FontSize="10"
                                                        Padding="6,1" ToolTip="Delete"
                                                        Command="{Binding DeleteCommand}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </TabItem>

                <TabItem Header="Groups" DataContext="{Binding GroupsTab}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Margin="10,6,10,4"
                                   Text="{Binding StatusText}"
                                   Foreground="{DynamicResource ForegroundDimBrush}"
                                   FontSize="11" VerticalAlignment="Center" />

                        <TextBlock Grid.Row="1" Text="No saved groups."
                                   Foreground="{DynamicResource ForegroundDimBrush}"
                                   FontSize="12" FontStyle="Italic"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}" />

                        <ItemsControl Grid.Row="1" ItemsSource="{Binding DisplayGroups}"
                                      Margin="0,2,0,0">
                            <ItemsControl.Template>
                                <ControlTemplate TargetType="ItemsControl">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </ControlTemplate>
                            </ItemsControl.Template>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="0,0,0,1" Padding="10,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Name}"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource ForegroundBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,0,0,2" Cursor="Hand"
                                                       MouseLeftButtonDown="GroupEntryName_MouseLeftButtonDown"
                                                       Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                                                <TextBlock.ToolTip>
                                                    <ToolTip Content="Click to rename" />
                                                </TextBlock.ToolTip>
                                            </TextBlock>
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                     FontSize="11" FontWeight="SemiBold"
                                                     Margin="0,0,0,2" Padding="0"
                                                     IsVisibleChanged="GroupEntryNameEdit_IsVisibleChanged"
                                                     LostFocus="GroupEntryNameEdit_LostFocus"
                                                     KeyDown="GroupEntryNameEdit_KeyDown"
                                                     Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}" />

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding ItemCountText}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource ForegroundDimBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="8,0,8,0" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding RelativeTime}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource ForegroundDimBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0" />

                                            <Menu Grid.Column="3"
                                                  Background="Transparent"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,4,0">
                                                <MenuItem Header="Restore" FontSize="10" Padding="6,2">
                                                    <MenuItem Header="Clear &amp; restore"
                                                              Command="{Binding RestoreCommand}"
                                                              CommandParameter="{x:Static models:GroupRestoreMode.ClearAndRestore}"
                                                              ToolTip="Replace history with this group" />
                                                    <MenuItem Header="Add to top"
                                                              Command="{Binding RestoreCommand}"
                                                              CommandParameter="{x:Static models:GroupRestoreMode.AddToTop}"
                                                              ToolTip="Insert group at top of history (newest first)" />
                                                    <MenuItem Header="Add to bottom"
                                                              Command="{Binding RestoreCommand}"
                                                              CommandParameter="{x:Static models:GroupRestoreMode.AddToBottom}"
                                                              ToolTip="Append group after current history" />
                                                </MenuItem>
                                            </Menu>

                                            <Button Grid.Column="4" Content="X" FontSize="10"
                                                    Padding="6,1" ToolTip="Delete group"
                                                    Command="{Binding DeleteCommand}"
                                                    VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</Window>
