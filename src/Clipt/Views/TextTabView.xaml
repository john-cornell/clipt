<UserControl x:Class="Clipt.Views.TextTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Clipt.Converters"
             xmlns:help="clr-namespace:Clipt.Help">
    <UserControl.Resources>
        <Style x:Key="StatLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundDimBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="StatValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AccentLightBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
            <Setter Property="Margin" Value="0,0,16,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolConverter x:Key="InverseBool" />
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="120" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="120" />
        </Grid.RowDefinitions>

        <!-- Stats bar -->
        <WrapPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Style="{StaticResource StatLabel}" Text="Characters:" />
            <TextBlock Style="{StaticResource StatValue}" Text="{Binding CharacterCount}" />
            <TextBlock Style="{StaticResource StatLabel}" Text="Lines:" />
            <TextBlock Style="{StaticResource StatValue}" Text="{Binding LineCount}" />
            <TextBlock Style="{StaticResource StatLabel}" Text="Null at:"
                       ToolTip="{x:Static help:HelpContent.NullTerminatorTooltip}" />
            <TextBlock Style="{StaticResource StatValue}" Text="{Binding NullTerminatorPosition}" />
            <TextBlock Style="{StaticResource StatLabel}" Text="Locale:"
                       ToolTip="{x:Static help:HelpContent.LocaleLcidTooltip}" />
            <TextBlock Style="{StaticResource StatValue}" Text="{Binding LocaleInfo}" />
        </WrapPanel>

        <TextBlock Grid.Row="1" Style="{StaticResource StatLabel}" Text="{Binding EncodingStats}" Margin="0,0,0,4"
                   ToolTip="{x:Static help:HelpContent.EncodingStatsTooltip}" />

        <!-- Edit toolbar -->
        <DockPanel Grid.Row="2" Margin="0,0,0,4">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="Apply to Clipboard" Command="{Binding ApplyTextToClipboardCommand}"
                        Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"
                        Margin="0,0,6,0" Padding="10,4" FontSize="11" />
                <Button Command="{Binding ToggleEditingCommand}" Padding="10,4" FontSize="11">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Content" Value="Edit" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                    <Setter Property="Content" Value="Cancel" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
            <TextBlock Text="{Binding EditStatusMessage}"
                       Foreground="{DynamicResource AccentLightBrush}" FontSize="11"
                       VerticalAlignment="Center" />
        </DockPanel>

        <!-- Unicode text -->
        <DockPanel Grid.Row="3">
            <TextBlock DockPanel.Dock="Top" Text="CF_UNICODETEXT (UTF-16)"
                       Foreground="{DynamicResource AccentLightBrush}" FontSize="11"
                       FontWeight="SemiBold" Margin="0,0,0,4"
                       ToolTip="{x:Static help:HelpContent.CfUnicodeTextTooltip}" />
            <TextBox x:Name="UnicodeTextBox"
                     Text="{Binding UnicodeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Style="{DynamicResource MonoText}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     IsInactiveSelectionHighlightEnabled="True"
                     IsReadOnly="{Binding IsEditing, Converter={StaticResource InverseBool}}" />
        </DockPanel>

        <!-- ANSI header -->
        <TextBlock Grid.Row="4" Text="CF_TEXT (ANSI)"
                   Foreground="{DynamicResource AccentLightBrush}" FontSize="11"
                   FontWeight="SemiBold" Margin="0,8,0,4"
                   ToolTip="{x:Static help:HelpContent.CfTextTooltip}" />

        <TextBox x:Name="AnsiTextBox"
                 Grid.Row="5" Text="{Binding AnsiText, Mode=OneWay}"
                 Style="{DynamicResource MonoText}"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 IsInactiveSelectionHighlightEnabled="True" />

        <!-- OEM header -->
        <TextBlock Grid.Row="6" Text="CF_OEMTEXT (OEM / CP437)"
                   Foreground="{DynamicResource AccentLightBrush}" FontSize="11"
                   FontWeight="SemiBold" Margin="0,8,0,4"
                   ToolTip="{x:Static help:HelpContent.CfOemTextTooltip}" />

        <TextBox x:Name="OemTextBox"
                 Grid.Row="7" Text="{Binding OemText, Mode=OneWay}"
                 Style="{DynamicResource MonoText}"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 IsInactiveSelectionHighlightEnabled="True" />
    </Grid>
</UserControl>
